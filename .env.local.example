# AWS Cognito Configuration
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=your-user-pool-id
NEXT_PUBLIC_USER_POOL_CLIENT_ID=your-client-id
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# AWS server access for Vercel route handlers
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
USERS_TABLE=Users
ATTACHMENTS_BUCKET=deadlinesync-attachments

# Optional fallback Canvas configuration
# Per-student Canvas tokens are stored in the Users table through the dashboard.
# These values are only used as a fallback/default.
CANVAS_ACCESS_TOKEN=
# Host only, e.g. mdc.instructure.com
CANVAS_DOMAIN=mdc.instructure.com

# AWS Cognito Configuration
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=your-user-pool-id
NEXT_PUBLIC_USER_POOL_CLIENT_ID=your-client-id
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# AWS server access for Vercel route handlers
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
USERS_TABLE=Users
ATTACHMENTS_BUCKET=deadlinesync-attachments

# Canvas values are now entered by each student in the dashboard.
# No global Canvas env vars are required.

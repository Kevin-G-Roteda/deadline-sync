# AWS Cognito Configuration
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=your-user-pool-id
NEXT_PUBLIC_USER_POOL_CLIENT_ID=your-client-id
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Canvas (server-only — set in Vercel as secrets, never commit real values)
# Personal Access Token from Canvas → Account → Settings → Approved Integrations
CANVAS_ACCESS_TOKEN=
# Host only, e.g. mdc.instructure.com
CANVAS_DOMAIN=mdc.instructure.com
